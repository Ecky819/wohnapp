rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isAuth() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    function isImage() {
      return request.resource.contentType.matches('image/.*');
    }

    function isDocument() {
      return request.resource.contentType.matches('image/.*') ||
             request.resource.contentType.matches('application/pdf') ||
             request.resource.contentType.matches('application/.*') ||
             request.resource.contentType.matches('text/.*');
    }

    function underSizeLimit(maxMb) {
      return request.resource.size <= maxMb * 1024 * 1024;
    }

    // ── tickets/{uid}/{ticketId}/img_N.jpg ────────────────────────────────────
    // Images: max 10 MB, image MIME types only
    match /tickets/{uid}/{ticketId}/{filename} {
      allow read:  if isAuth();
      allow write: if isOwner(uid) && isImage() && underSizeLimit(10);
    }

    // ── tickets/{uid}/{ticketId}/docs/{filename} ──────────────────────────────
    // Documents: max 20 MB, images + PDF + office formats
    match /tickets/{uid}/{ticketId}/docs/{filename} {
      allow read:  if isAuth();
      allow write: if isOwner(uid) && isDocument() && underSizeLimit(20);
    }
  }
}

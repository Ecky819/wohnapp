rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isAuth() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    function isImage() {
      return request.resource.contentType.matches('image/.*');
    }

    function isPdf() {
      return request.resource.contentType == 'application/pdf';
    }

    function isDocument() {
      return isImage() || isPdf();
    }

    function underSizeLimit(maxMb) {
      return request.resource.size <= maxMb * 1024 * 1024;
    }

    // ── tickets/{uid}/{ticketId}/img_N.jpg ────────────────────────────────────
    // Images: max 10 MB, image MIME types only
    match /tickets/{uid}/{ticketId}/{filename} {
      allow read:  if isAuth();
      allow write: if isOwner(uid) && isImage() && underSizeLimit(10);
    }

    // ── tickets/{uid}/{ticketId}/docs/{filename} ──────────────────────────────
    // Documents: max 10 MB, images + PDF only
    match /tickets/{uid}/{ticketId}/docs/{filename} {
      allow read:  if isAuth();
      allow write: if isOwner(uid) && isDocument() && underSizeLimit(10);
    }

    // ── invoices/{uid}/{invoiceId}.pdf ────────────────────────────────────────
    // Invoice PDFs: max 10 MB, PDF only
    match /invoices/{uid}/{filename} {
      allow read:  if isAuth();
      allow write: if isOwner(uid) && isPdf() && underSizeLimit(10);
    }

    // ── statements/{tenantId}/{filename} ─────────────────────────────────────
    // Abrechnungs-PDFs: max 10 MB, PDF only
    match /statements/{tenantId}/{filename} {
      allow read:  if isAuth();
      allow write: if isAuth() && isPdf() && underSizeLimit(10);
    }

    // ── statements/{tenantId}/receipts/{filename} ─────────────────────────────
    // Belegbilder: max 10 MB, Bilder only (§ 259 BGB: Mieter hat Einsichtsrecht)
    match /statements/{tenantId}/receipts/{filename} {
      allow read:  if isAuth();
      allow write: if isAuth() && isImage() && underSizeLimit(10);
    }
  }
}

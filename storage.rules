rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ─── Hilfsfunktionen ──────────────────────────────────────────────────────

    function isAuth() {
      return request.auth != null && request.auth.uid != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    function isImage() {
      return request.resource.contentType.matches('image/.*');
    }

    function isPdf() {
      return request.resource.contentType == 'application/pdf';
    }

    function isDocument() {
      return isImage() || isPdf();
    }

    function underSizeLimit(maxMb) {
      return request.resource.size <= maxMb * 1024 * 1024;
    }

    // Liest Rolle und tenantId des eingeloggten Users aus Firestore.
    function userDoc() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data;
    }

    function isManager() {
      return isAuth() && userDoc().role == 'manager';
    }

    function userTenantId() {
      return userDoc().tenantId;
    }

    // ── tickets/{uid}/{ticketId}/{filename} ───────────────────────────────────
    // Ticket-Fotos: nur Besitzer schreibt, nur eingeloggte Nutzer lesen.
    // Feine Zugangsprüfung (Mandant) via Firestore-Rules auf dem Dokument,
    // Storage-URLs sind nicht öffentlich auffindbar.
    match /tickets/{uid}/{ticketId}/{filename} {
      allow read:  if isAuth();
      allow write: if isOwner(uid) && isImage() && underSizeLimit(10);
    }

    // ── tickets/{uid}/{ticketId}/docs/{filename} ──────────────────────────────
    match /tickets/{uid}/{ticketId}/docs/{filename} {
      allow read:  if isAuth();
      allow write: if isOwner(uid) && isDocument() && underSizeLimit(10);
    }

    // ── invoices/{uid}/{filename} ─────────────────────────────────────────────
    // Rechnungs-PDFs: Handwerker lädt hoch (uid = eigene uid).
    match /invoices/{uid}/{filename} {
      allow read:  if isAuth();
      allow write: if isOwner(uid) && isPdf() && underSizeLimit(10);
    }

    // ── statements/{tenantId}/{filename} ─────────────────────────────────────
    // Betriebskosten-Abrechnungs-PDFs: nur Manager des Mandanten darf schreiben.
    match /statements/{tenantId}/{filename} {
      allow read:  if isAuth() && userTenantId() == tenantId;
      allow write: if isManager() &&
        userTenantId() == tenantId &&
        isPdf() &&
        underSizeLimit(10);
    }

    // ── statements/{tenantId}/receipts/{filename} ─────────────────────────────
    // Belegbilder (§ 259 BGB: Mieter hat Einsichtsrecht auf Belege).
    match /statements/{tenantId}/receipts/{filename} {
      allow read:  if isAuth() && userTenantId() == tenantId;
      allow write: if isManager() &&
        userTenantId() == tenantId &&
        isImage() &&
        underSizeLimit(10);
    }

    // ── logos/{tenantId}/{filename} ───────────────────────────────────────────
    // Mandanten-Logo für White-Label-Branding.
    // Lesen: alle eingeloggten Nutzer (App-Theming braucht das Logo).
    // Schreiben: nur Manager des eigenen Mandanten, max 2 MB, nur Bilder.
    match /logos/{tenantId}/{filename} {
      allow read:  if isAuth();
      allow write: if isManager() &&
        userTenantId() == tenantId &&
        isImage() &&
        underSizeLimit(2);
      allow delete: if isManager() && userTenantId() == tenantId;
    }

  }
}

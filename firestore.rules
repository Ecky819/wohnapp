rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ═══════════════════════════════════════════════════════════════════════════
    // HILFSFUNKTIONEN
    // ═══════════════════════════════════════════════════════════════════════════

    function isAuth() {
      return request.auth != null;
    }

    function isAnonymous() {
      return isAuth() &&
        request.auth.token.firebase.sign_in_provider == 'anonymous';
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function userRole() {
      return userDoc().role;
    }

    function userTenantId() {
      return userDoc().tenantId;
    }

    function isManager() {
      return isAuth() && !isAnonymous() && userRole() == 'manager';
    }

    function isContractor() {
      return isAuth() && !isAnonymous() && userRole() == 'contractor';
    }

    function isTenantUser() {
      return isAuth() && !isAnonymous() && userRole() == 'tenant_user';
    }

    // Prüft ob ein Dokument zum selben Mandanten gehört wie der eingeloggte User.
    function sameTenant(data) {
      return data.tenantId == userTenantId();
    }

    // Prüft ob genau diese Felder (und keine anderen) geändert werden.
    function onlyFields(allowedKeys) {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(allowedKeys);
    }

    // ═══════════════════════════════════════════════════════════════════════════
    // users/{uid}
    // ═══════════════════════════════════════════════════════════════════════════

    match /users/{uid} {
      // Jeder User liest sein eigenes Dokument.
      // Manager lesen Nutzer desselben Mandanten (Handwerker-Zuweisung, Listen).
      allow read: if isAuth() && (
        request.auth.uid == uid ||
        (isManager() && resource.data.tenantId == userTenantId())
      );

      // Erstellen nur bei eigener Registrierung.
      allow create: if isAuth() && request.auth.uid == uid;

      // Eigenes Dokument updaten (z.B. FCM-Token, Profilbild).
      // Manager darf Nutzer desselben Mandanten updaten (Rolle setzen etc.).
      allow update: if isAuth() && (
        request.auth.uid == uid ||
        (isManager() && resource.data.tenantId == userTenantId())
      );

      // Nutzer werden nie gelöscht (Audit-Trail für Tickethistorie).
      allow delete: if false;
    }

    // ═══════════════════════════════════════════════════════════════════════════
    // tickets/{ticketId}
    // ═══════════════════════════════════════════════════════════════════════════

    match /tickets/{ticketId} {
      // Manager: alle Tickets des eigenen Mandanten.
      allow read: if isManager() && sameTenant(resource.data);

      // Mieter: nur eigene Tickets.
      allow read: if isTenantUser() &&
        resource.data.createdBy == request.auth.uid;

      // Handwerker: nur zugewiesene Tickets.
      allow read: if isContractor() &&
        resource.data.assignedTo == request.auth.uid;

      // Mieter erstellt Ticket für sich selbst.
      allow create: if isTenantUser() &&
        request.resource.data.createdBy == request.auth.uid &&
        request.resource.data.tenantId == userTenantId() &&
        request.resource.data.status == 'open';

      // Anonymer Gast (QR-Code-Flow) erstellt Ticket.
      allow create: if isAnonymous() &&
        request.resource.data.createdBy == request.auth.uid &&
        request.resource.data.status == 'open' &&
        request.resource.data.tenantId is string &&
        request.resource.data.tenantId.size() > 0;

      // Manager erstellt Ticket (z.B. Wartungsticket).
      allow create: if isManager() &&
        request.resource.data.tenantId == userTenantId();

      // Manager darf alle Felder im Ticket ändern (Status, Zuweisung, Versicherungsfall …).
      allow update: if isManager() && sameTenant(resource.data);

      // Handwerker darf nur Status, Termin und Ablehnen der Zuweisung ändern.
      // insuranceClaim und alle anderen Felder sind explizit gesperrt.
      allow update: if isContractor() &&
        resource.data.assignedTo == request.auth.uid &&
        onlyFields(['status', 'scheduledAt', 'assignedTo', 'assignedToName']);

      // Keine Löschung (Audit-Trail).
      allow delete: if false;

      // ── tickets/{ticketId}/comments/{commentId} ────────────────────────────
      match /comments/{commentId} {
        // Nur Ticket-Beteiligte dürfen Kommentare lesen.
        allow read: if isAuth() && !isAnonymous() && (
          isManager() ||
          get(/databases/$(database)/documents/tickets/$(ticketId)).data.assignedTo == request.auth.uid ||
          get(/databases/$(database)/documents/tickets/$(ticketId)).data.createdBy  == request.auth.uid
        );

        allow create: if isAuth() && !isAnonymous() &&
          request.resource.data.authorId == request.auth.uid;

        // Nur Autor darf eigenen Kommentar löschen.
        allow delete: if isAuth() &&
          resource.data.authorId == request.auth.uid;

        allow update: if false;
      }

      // ── tickets/{ticketId}/activity/{entryId} ─────────────────────────────
      match /activity/{entryId} {
        allow read: if isAuth() && !isAnonymous() && (
          isManager() ||
          get(/databases/$(database)/documents/tickets/$(ticketId)).data.assignedTo == request.auth.uid ||
          get(/databases/$(database)/documents/tickets/$(ticketId)).data.createdBy  == request.auth.uid
        );

        allow create: if isAuth() && !isAnonymous() &&
          request.resource.data.actorId == request.auth.uid;

        allow update, delete: if false;
      }
    }

    // ═══════════════════════════════════════════════════════════════════════════
    // buildings/{buildingId}
    // ═══════════════════════════════════════════════════════════════════════════

    match /buildings/{buildingId} {
      allow read: if isAuth() && !isAnonymous() &&
        resource.data.tenantId == userTenantId();

      allow create, update: if isManager() &&
        request.resource.data.tenantId == userTenantId();

      allow delete: if false;
    }

    // ═══════════════════════════════════════════════════════════════════════════
    // units/{unitId}
    // ═══════════════════════════════════════════════════════════════════════════

    match /units/{unitId} {
      allow read: if isAuth() && !isAnonymous() &&
        resource.data.tenantId == userTenantId();

      allow create, update: if isManager() &&
        request.resource.data.tenantId == userTenantId();

      allow delete: if false;

      // ── units/{unitId}/devices/{deviceId} ─────────────────────────────────
      match /devices/{deviceId} {
        // Alle Mandanten-Nutzer dürfen Geräte lesen (Digital Twin).
        allow read: if isAuth() && !isAnonymous() && (
          resource.data.tenantId == userTenantId() ||
          !('tenantId' in resource.data)  // Fallback für ältere Dokumente
        );

        // Nur Manager darf Geräte anlegen, bearbeiten, löschen.
        // lastMaintenanceAlertSentAt + lastSensorAlert werden nur via Admin SDK
        // (Cloud Functions) geschrieben und brauchen keine Client-Rule.
        allow create, update, delete: if isManager();
      }
    }

    // ═══════════════════════════════════════════════════════════════════════════
    // invitations/{code}
    // ═══════════════════════════════════════════════════════════════════════════

    match /invitations/{code} {
      // Jeder eingeloggte User darf Einladung lesen (für Registrierungs-Validierung).
      allow read: if isAuth();

      // Nur Manager darf Einladungen erstellen.
      allow create: if isManager() &&
        request.resource.data.createdBy == request.auth.uid;

      // Registrierung: nur used + usedAt darf gesetzt werden.
      // Manager darf alles im eigenen Mandanten ändern.
      allow update: if isAuth() && (
        isManager() ||
        onlyFields(['used', 'usedAt'])
      );

      allow delete: if false;
    }

    // ═══════════════════════════════════════════════════════════════════════════
    // invoices/{invoiceId}
    // ═══════════════════════════════════════════════════════════════════════════

    match /invoices/{invoiceId} {
      allow read: if isManager() && resource.data.tenantId == userTenantId();

      allow read: if isContractor() &&
        resource.data.contractorId == request.auth.uid;

      // Handwerker legt Rechnung für sich selbst an.
      allow create: if isContractor() &&
        request.resource.data.contractorId == request.auth.uid &&
        request.resource.data.tenantId == userTenantId() &&
        request.resource.data.status == 'pending';

      // Handwerker trägt PDF-URL nach dem Upload nach.
      allow update: if isContractor() &&
        resource.data.contractorId == request.auth.uid &&
        onlyFields(['pdfUrl']);

      // Manager darf Status, Ablehnungsgrund, Genehmigungsdatum und Export-Status setzen.
      // hasOnly stellt sicher, dass kein anderes Feld heimlich mitgeändert wird.
      allow update: if isManager() &&
        resource.data.tenantId == userTenantId() &&
        onlyFields(['status', 'rejectionReason', 'approvedAt', 'exportedAt']);

      allow delete: if false;
    }

    // ═══════════════════════════════════════════════════════════════════════════
    // statements/{statementId}
    // Jahresabrechnungen (§ 556 BGB)
    // ═══════════════════════════════════════════════════════════════════════════

    match /statements/{statementId} {
      allow read: if isManager() && resource.data.tenantId == userTenantId();

      // Mieter liest nur eigene Abrechnung.
      allow read: if isTenantUser() &&
        resource.data.recipientId == request.auth.uid;

      allow create: if isManager() &&
        request.resource.data.tenantId == userTenantId() &&
        request.resource.data.createdBy == request.auth.uid;

      // Mieter bestätigt Empfang — nur diese drei Felder dürfen sich ändern.
      allow update: if isTenantUser() &&
        resource.data.recipientId == request.auth.uid &&
        onlyFields(['status', 'acknowledgedAt', 'acknowledgedBy']);

      // Manager darf Status nachträglich korrigieren.
      allow update: if isManager() &&
        resource.data.tenantId == userTenantId() &&
        onlyFields(['status', 'sentAt']);

      allow delete: if false;
    }

    // ═══════════════════════════════════════════════════════════════════════════
    // tenants/{tenantId}
    // ═══════════════════════════════════════════════════════════════════════════

    match /tenants/{tenantId} {
      // Alle eingeloggten Nutzer des Mandanten dürfen das Branding lesen
      // (dynamisches Theming, Logo, Primärfarbe).
      // Anonyme Nutzer sind ausgeschlossen.
      allow read: if isAuth() && !isAnonymous() &&
        tenantId == userTenantId();

      // Nur Manager darf Tenant-Einstellungen anlegen / ändern.
      allow create, update: if isManager() && tenantId == userTenantId();

      allow delete: if false;
    }

    // ═══════════════════════════════════════════════════════════════════════════
    // notifications/{notifId}
    // ═══════════════════════════════════════════════════════════════════════════

    match /notifications/{notifId} {
      // Eingeloggte Nutzer dürfen Notifications anlegen
      // (Cross-User-Trigger für Status-Änderungen, Zuweisungen, Kommentare).
      // Die Cloud Function sendet die eigentliche FCM-Nachricht via Admin SDK.
      allow create: if isAuth() && !isAnonymous();

      // User liest nur seine eigenen Notifications.
      allow read: if isAuth() &&
        resource.data.targetUserId == request.auth.uid;

      // Update und Löschen nur via Admin SDK (Cloud Functions).
      allow update, delete: if false;
    }

    // ═══════════════════════════════════════════════════════════════════════════
    // sensor_readings/{readingId}
    // IoT-Sensor-Messwerte — werden ausschließlich via Cloud Function
    // (Admin SDK) geschrieben. Flutter liest nur.
    // ═══════════════════════════════════════════════════════════════════════════

    match /sensor_readings/{readingId} {
      // Manager und alle Mandanten-Nutzer dürfen Sensor-Daten des eigenen
      // Mandanten lesen (Digital Twin, Live-Dashboard).
      allow read: if isAuth() && !isAnonymous() &&
        resource.data.tenantId == userTenantId();

      // Kein Client-seitiges Schreiben — nur Cloud Functions via Admin SDK.
      allow create, update, delete: if false;
    }

  }
}
